<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <TextView
        android:id="@+id/appName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Breezy Assistant"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@+id/btnThreatScan"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <Button
        android:id="@+id/btnThreatScan"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Threat Scan"
        app:layout_constraintBottom_toTopOf="@+id/btnAiBrain"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/appName" />

    <Button
        android:id="@+id/btnAiBrain"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="AI Brain Setup"
        app:layout_constraintBottom_toTopOf="@+id/btnMorningReport"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btnThreatScan" />

    <Button
        android:id="@+id/btnMorningReport"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Morning Report"
        app:layout_constraintBottom_toTopOf="@+id/btnPrivacyNote"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btnAiBrain" />

    <Button
        android:id="@+id/btnPrivacyNote"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Privacy Note"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btnMorningReport" />

</androidx.constraintlayout.widget.ConstraintLayout>
